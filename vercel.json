{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install && cd client && npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "crons": [
    {
      "path": "/api/cron/digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/notion-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
