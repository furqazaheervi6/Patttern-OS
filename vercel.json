{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install && cd client && npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "crons": [
    { "path": "/api/cron/morning-brief", "schedule": "0 7 * * *" },
    { "path": "/api/cron/notion-sync",   "schedule": "0 6 * * *" },
    { "path": "/api/cron/digest",        "schedule": "0 8 * * 1" },
    { "path": "/api/cron/pattern-alerts",    "schedule": "0 20 * * *" },
    { "path": "/api/cron/research-agent",    "schedule": "0 6 * * *"  },
    { "path": "/api/cron/memory-extraction", "schedule": "0 3 * * 1"  },
    { "path": "/api/cron/pattern-analysis",  "schedule": "0 4 * * 1"  }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api|assets|favicon|manifest|sw|icon|apple).*)", "destination": "/index.html" }
  ]
}
