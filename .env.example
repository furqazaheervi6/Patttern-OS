# ─── Database (Required) ─────────────────────────────────
# Get this from Supabase: Project Settings > Database > Connection string (URI)
# Use the "Transaction" pooler (port 6543) for serverless
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── AI / Claude (Required for digests & alerts) ────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Notion (Optional) ──────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=
NOTION_PAGE_ID=

# ─── Google Calendar (Optional) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/google/auth/callback
GOOGLE_REFRESH_TOKEN=

# ─── Vercel Cron (Set on Vercel dashboard) ──────────────
CRON_SECRET=

# ─── Client URL (Set on Vercel dashboard) ───────────────
CLIENT_URL=https://your-app.vercel.app

# ─── Local Dev ──────────────────────────────────────────
PORT=3001
